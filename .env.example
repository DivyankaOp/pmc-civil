# ── PMC Civil AI — Environment Variables ──
# Copy this file to .env and fill in your keys

# REQUIRED: Claude API key
# Get from: console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX

# RECOMMENDED: Google Cloud Vision API key
# Scanned PDFs aur image drawings ke liye zaroori hai
# Bina is key ke scanned drawings ka schedule table galat padha jayega
#
# Kaise banaye (FREE):
# 1. console.cloud.google.com pe jao
# 2. New Project → APIs & Services → Library
# 3. "Cloud Vision API" search karo → Enable karo
# 4. Credentials → Create Credentials → API Key
GOOGLE_CLOUD_VISION_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OPTIONAL: Gemini key
# Sirf legacy /gemini chat route ke liye — baaki sab Claude use karta hai
GEMINI_API_KEY=

# Server port
PORT=3000

# ── PMC Civil AI — Environment Variables ──
# Copy this file to .env and fill in your keys

# ─────────────────────────────────────────────
# REQUIRED: Claude API key
# Get from: console.anthropic.com
# ─────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────
# RECOMMENDED: Google Cloud Vision API key
# Yeh key scanned PDFs aur image drawings ke liye zaroori hai
# Bina is key ke scanned drawings ka schedule table galat padha jayega
#
# Kaise banaye (FREE — ~Rs.12 per 100 drawings):
# 1. console.cloud.google.com pe jao
# 2. New Project banao (ya existing select karo)
# 3. Left menu → APIs & Services → Library
# 4. "Cloud Vision API" search karo → Enable karo
# 5. APIs & Services → Credentials → Create Credentials → API Key
# 6. Woh key yahan paste karo
# ─────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────
# OPTIONAL: Gemini key
# Sirf legacy /gemini chat route ke liye
# Sab drawing analysis Claude API use karta hai — yeh optional hai
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Server port (default: 3000)
# ─────────────────────────────────────────────
PORT=3000

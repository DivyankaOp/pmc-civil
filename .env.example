# ── PMC Civil AI — Environment Variables ──
# Copy this file to .env and fill in your keys

# REQUIRED: Claude API key (get from console.anthropic.com)
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX

# OPTIONAL: Gemini key — only needed for the legacy /gemini chat route
# All drawing analysis (DXF, DWG, PDF, ZWCAD) now uses Claude API
# Leave blank to disable /gemini chat; all other routes will still work
GEMINI_API_KEY=

PORT=3000
